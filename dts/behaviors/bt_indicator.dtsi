#include <dt-bindings/zmk/behaviors.h>

/ {
    behaviors {
        /omit-if-no-ref/
        bt_ind: bt_ind {
            compatible = "zmk,behavior-bt-indicator";
            #binding-cells = <0>;
            display-name = "Bluetooth RGB Indicator";
        };
    };
};
